---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<Base
  title="John Abrahams"
  description="John Abrahams — masters in data science at Penn. Systems, ML, and the occasional paper."
  current="home"
>
  <!-- Hero -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">MS in Data Science · University of Pennsylvania · '27</span>
      <h1 class="display display-lg hero-title">John Abrahams</h1>
      <p class="hero-subtitle">Computer Science &amp; Data Science.</p>
      <p class="lead hero-lead">
        Currently a master&rsquo;s student in Data Science at the
        <strong>University of Pennsylvania</strong>, and co-author of
        <a href="/projects/khronos">Khronos</a>, a multi-tenant WebAssembly runtime. Before
        Penn — BS in Computer Science &amp; Engineering at Lehigh, parallel WebAssembly with
        Prof.&nbsp;Spear, a clinical therapy chatbot at New York Brain &amp; Spine Surgery
        (through March 2026), and a fintech sim with 61M data points.
      </p>
      <ul class="hero-meta">
        <li><span class="mono">now</span> &nbsp;Penn MS coursework · Khronos paper.</li>
        <li><span class="mono">prev</span> &nbsp;NYBSS therapy chatbot ('25–'26) · BSCS Lehigh '25 · Dean's list 4 semesters · GPA 3.65</li>
        <li><span class="mono">stack</span> &nbsp;Rust · Go · Python · C++ · WebAssembly · PyTorch · AWS</li>
      </ul>
    </div>
  </section>

  <hr class="rule" />

  <!-- Featured -->
  <section class="section" id="projects">
    <div class="container">
      <span class="eyebrow">Featured</span>
      <h2 class="display display-sm section-title">Two larger things.</h2>
      <div class="featured-list">
        <ProjectCard
          featured={true}
          href="/projects/khronos"
          title="Khronos — A Type II Exovisor with WebAssembly"
          tags="2025 · Rust · co-authored paper"
          blurb="A multi-tenant runtime that combines WebAssembly's sandbox with exokernel-style capability gating and a custom wasi:thread-spawn dispatcher. ~5,000 lines of Rust; ~0.08 MiB per isolate (3× denser than Wasmtime); up to 6.7× speedup on dense matmul while preserving per-tenant trap containment."
        />
        <ProjectCard
          featured={true}
          href="/projects/dj-rl-system"
          title="DJ Reinforcement Learning System"
          tags="Dec 2025 · embedded · GRU + RL"
          blurb="A wireless ESP32-S2 sensor mesh — environmental, audio, thermal — that streams crowd-engagement metrics to a Raspberry Pi controller. A 2M-parameter GRU pretrained on ~3,000 DJ sets predicts the next song; an RL head adapts to live sensor feedback. Built with Chris Spletzer for UPenn ESE 519."
        />
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Projects -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">Projects</span>
      <h2 class="display display-sm section-title">Smaller things.</h2>
      <div class="card-list">
        <ProjectCard
          href="/projects/therapy-chatbot"
          title="Clinical Therapy Chatbot"
          tags="May 2025 – Mar 2026 · LLaMA · FastAPI"
          blurb="A production therapy chatbot for New York Brain & Spine Surgery, blending rule-based clinical workflows with LLM-generated responses. Configurable multi-agent system spanning multiple mental-health conditions."
        />
        <ProjectCard
          href="/projects/quant-game"
          title="The Quant Game"
          tags="2024 · co-founded · React + Python + AWS"
          blurb="A full-stack options-trading sim with 61M financial data points on AWS. Users build and backtest strategies and watch them play out against historical market data."
        />
        <ProjectCard
          href="/projects/capstone-search"
          title="Dropbox Document Search Engine"
          tags="2024 · capstone · NLP + AWS"
          blurb="A search engine for ~23,000 Dropbox documents, with sentence-level highlight extraction. Partitioned indexing + Dropbox API integration for real-time access. Lehigh capstone for an early-stage startup."
        />
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Writing -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">Writing</span>
      <h2 class="display display-sm section-title">Selected papers.</h2>
      <ul class="writing-list">
        <li>
          <a href="/papers/khronos.pdf" target="_blank" rel="noopener">
            <span class="w-title">Khronos: A Type II Exovisor Architecture with WebAssembly</span>
            <span class="w-meta">2025 · with Ajax Li · IEEE format</span>
          </a>
        </li>
        <li>
          <a href="/papers/zimvie-acdf-predictive-modeling.pdf" target="_blank" rel="noopener">
            <span class="w-title">Predictive Outcome Modeling After ACDF (LDR-C ROI Implant)</span>
            <span class="w-meta">2024 · co-author · 236-patient cohort study</span>
          </a>
        </li>
        <li>
          <a href="/papers/gradient-descent-analysis.pdf" target="_blank" rel="noopener">
            <span class="w-title">Gradient Descent Analysis</span>
            <span class="w-meta">2023 · with Prof.&nbsp;Arielle Carr · Lehigh</span>
          </a>
        </li>
        <li>
          <a href="/papers/highlighting-algorithm.pdf" target="_blank" rel="noopener">
            <span class="w-title">A Highlighting Algorithm for Document Search</span>
            <span class="w-meta">2024 · capstone writeup</span>
          </a>
        </li>
      </ul>
      <p class="writing-more">
        Full list and reading notes on the <a href="/writing">writing page</a>.
      </p>
    </div>
  </section>
</Base>

<style>
  .hero-title { margin-top: 1.2rem; }
  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 2.6vw, 1.85rem);
    font-style: italic;
    color: var(--ink-muted);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-top: 0.5rem;
  }
  .hero-lead { margin-top: 1.75rem; max-width: 60ch; }
  .hero-lead a { border-bottom: 1px solid var(--rule-strong); }
  .hero-lead strong { font-weight: 600; color: var(--ink); }
  .hero-meta {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.92rem;
    color: var(--ink-muted);
  }
  .hero-meta .mono {
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.7rem;
    margin-right: 0.25rem;
  }

  .section-title { margin-top: 0.6rem; margin-bottom: 1.5rem; }

  .featured-list, .card-list {
    display: flex;
    flex-direction: column;
  }

  .writing-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .writing-list li {
    border-top: 1px solid var(--rule);
  }
  .writing-list li:last-child { border-bottom: 1px solid var(--rule); }
  .writing-list a {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1rem 0;
    border: none;
    transition: padding-left var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .writing-list a:hover {
    color: var(--accent);
    padding-left: 0.5rem;
  }
  .w-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.3;
  }
  .w-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }
  .writing-more {
    margin-top: 1.5rem;
    font-size: 0.92rem;
    color: var(--ink-muted);
  }
  @media (max-width: 600px) {
    .writing-list a { grid-template-columns: 1fr; gap: 0.3rem; }
    .w-meta { white-space: normal; }
  }
</style>
